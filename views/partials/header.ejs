<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="/css/output.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <title>ShooraShop</title>
</head>

<body class="bg-white text-gray-900">

    <!-- NAVBAR -->
    <header id="navbar" class="sticky top-0 z-50 bg-white transition-all duration-300">
        <div class="flex justify-between items-center px-6 py-4 md:px-10 max-w-[1400px] mx-auto">

            <!-- Logo -->
            <a href="/">
                <img src="/assets/icons/logo.svg" alt="Forever Logo" class="w-32 md:w-36" />
            </a>
            <!-- Desktop Nav Links -->
            <nav class="hidden lg:flex">
                <ul class="flex gap-6 text-base text-gray-700 items-center">
                    <li><a href="/" class="hover:text-black transition flex items-center gap-1">Home</a></li>
                    <li><a href="/products" class="hover:text-black transition">All Products</a></li>
                    <li><a href="/about" class="hover:text-black transition">About</a></li>
                    <li><a href="/contact" class="hover:text-black transition">Contact</a></li>
                </ul>
            </nav>

            <!-- Search Bar + Icons (Desktop) -->
            <div class="hidden md:flex items-center gap-4">
                <div class="flex items-center bg-gray-100 rounded-lg px-3 py-2 w-48 lg:w-56">
                    <input type="text" placeholder="Search..."
                        class="bg-transparent outline-none text-sm flex-1 text-gray-700" />
                    <i class="fa fa-search text-gray-500 text-sm"></i>
                </div>
                <a href="/signin">
                    <i class="fa fa-user text-lg text-gray-700 hover:text-black transition cursor-pointer"></i>
                </a>
                <a href="/favourite">
                    <i class="fa fa-heart text-lg text-gray-700 hover:text-black transition cursor-pointer"></i>

                </a>
                <div class="relative cursor-pointer">
                    <a href="/cart">
                        <i class="fa fa-shopping-cart text-lg text-gray-700 hover:text-black transition"></i>
                        <% if (typeof cartCount !=='undefined' && cartCount> 0) { %>
                            <span
                                class="absolute -top-2 -right-2 bg-black text-white text-[10px] w-4 h-4 rounded-full flex items-center justify-center font-bold">
                                <%= cartCount %>
                            </span>
                            <% } %>
                    </a>
                </div>
            </div>

            <!-- Mobile Icons + Hamburger -->
            <div class="md:hidden flex items-center gap-4">
                <div class="relative cursor-pointer">
                    <a href="/cart">
                        <i class="fa fa-shopping-cart text-xl text-gray-700"></i>
                        <% if (typeof cartCount !=='undefined' && cartCount> 0) { %>
                            <span
                                class="absolute -top-2 -right-2 bg-black text-white text-[10px] w-4 h-4 rounded-full flex items-center justify-center font-bold">
                                <%= cartCount %>
                            </span>
                            <% } %>
                    </a>
                </div>
                <a href="/signin">
                    <i class="fa fa-user text-xl text-gray-700"></i>
                </a>
                <button onclick="toggleMenu()" class="text-2xl cursor-pointer text-gray-700">
                    <i class="fa fa-bars" id="menu-icon"></i>
                </button>
            </div>

        </div>

        <!-- Mobile Menu -->
        <div id="mobile-menu" class="hidden md:hidden bg-white border-t mx-5 mt-1 p-4 rounded-b-2xl shadow-lg">
            <div class="flex items-center bg-gray-100 rounded-lg px-3 py-2 mb-4">
                <input type="text" placeholder="Search..."
                    class="bg-transparent outline-none text-sm flex-1 text-gray-700" />
                <i class="fa fa-search text-gray-500 text-sm"></i>
            </div>
            <ul class="flex flex-col gap-3 text-sm text-gray-700">
                <li class="py-2 border-b border-gray-100"><a href="/" class="hover:text-black block">Home</a></li>
                <li class="py-2 border-b border-gray-100"><a href="/products"
                        class="hover:text-black block">Products</a></li>
                <li class="py-2 border-b border-gray-100"><a href="/products" class="hover:text-black block">Gift
                        Cards</a></li>
                <li class="py-2"><a href="/sign-in" class="hover:text-black block">Sign In</a></li>
            </ul>
        </div>
    </header>

    <script>
        // Shadow on scroll
        window.addEventListener('scroll', function () {
            const navbar = document.getElementById('navbar');
            navbar.classList.toggle('shadow-md', window.scrollY > 10);
        });

        // Mobile menu toggle
        function toggleMenu() {
            const menu = document.getElementById('mobile-menu');
            const icon = document.getElementById('menu-icon');
            const isOpen = !menu.classList.contains('hidden');
            menu.classList.toggle('hidden');
            icon.className = isOpen ? 'fa fa-bars' : 'fa fa-times';
        }
    </script>