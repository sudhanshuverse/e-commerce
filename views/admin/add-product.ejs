<%- include('../partials/header') %>

    <div class="min-h-screen bg-gray-50">
        <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
            <!-- Page Header -->
            <div class="mb-8">
                <a href="/admin/products" class="inline-flex items-center gap-2 text-sm text-gray-400 hover:text-indigo-600 transition mb-4">
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
                    </svg>Back to Products
                </a>
                <div class="flex items-center gap-3">
                    <span class="w-1 h-8 bg-indigo-500 rounded-full"></span>
                    <div>
                        <p class="text-xs uppercase tracking-widest text-gray-400">Dashboard</p>
                        <h1 class="text-3xl font-extrabold tracking-tight text-gray-900">Add <span class="text-indigo-600">Product</span></h1>
                    </div>
                </div>
            </div>

            <!-- Form Card -->
            <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6 sm:p-8">
                <form action="/admin/add-product" method="POST" class="space-y-6">
                    <!-- Product Name -->
                    <div>
                        <label class="block text-xs font-semibold uppercase tracking-wider text-gray-500 mb-2">Product Name</label>
                        <input name="name" required placeholder="e.g. Nike Air Max 90" class="w-full bg-gray-50 border border-gray-200 rounded-xl px-4 py-3 text-sm text-gray-800 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-indigo-400 focus:border-transparent transition" />
                    </div>
                    <!-- Price + Category -->
                    <div class="grid sm:grid-cols-2 gap-4">
                        <div>
                            <label class="block text-xs font-semibold uppercase tracking-wider text-gray-500 mb-2">Price (&#8377;) </label>
                            <div class="relative">
                                <span class="absolute left-4 top-1/2 -translate-y-1/2 text-gray-400 text-sm font-semibold">&#8377; </span>
                                <input name="price" type="number" required placeholder="0.00" class="w-full bg-gray-50 border border-gray-200 rounded-xl pl-8 pr-4 py-3 text-sm text-gray-800 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-indigo-400 focus:border-transparent transition" />
                            </div>
                        </div>
                        <div>
                            <label class="block text-xs font-semibold uppercase tracking-wider text-gray-500 mb-2">Category
                            </label>
                            <input name="category" placeholder="e.g. Sneakers" class="w-full bg-gray-50 border border-gray-200 rounded-xl px-4 py-3 text-sm text-gray-800 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-indigo-400 focus:border-transparent transition" />
                        </div>
                    </div>

                    <!-- Image URL -->
                    <div>
                        <label class="block text-xs font-semibold uppercase tracking-wider text-gray-500 mb-2">Image URL</label>
                        <input name="img" placeholder="https://example.com/image.jpg" class="w-full bg-gray-50 border border-gray-200 rounded-xl px-4 py-3 text-sm text-gray-800 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-indigo-400 focus:border-transparent transition" />
                    </div>

                    <!-- Description -->
                    <div>
                        <label class="block text-xs font-semibold uppercase tracking-wider text-gray-500 mb-2">Description</label>
                        <textarea name="description" rows="4" placeholder="Write a short product description..." class="w-full bg-gray-50 border border-gray-200 rounded-xl px-4 py-3 text-sm text-gray-800 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-indigo-400 focus:border-transparent transition resize-none"></textarea>
                    </div>

                    <!-- Divider -->
                    <div class="border-t border-gray-100"></div>

                    <!-- Submit -->
                    <div class="flex items-center justify-between">
                        <a href="/admin/products" class="text-sm text-gray-400 hover:text-gray-600 transition">Cancel</a>
                        <button type="submit" class="inline-flex items-center gap-2 px-8 py-3 bg-indigo-600 text-white text-sm font-semibold rounded-xl shadow-md hover:bg-indigo-700 active:scale-95 transition-all duration-150">
                            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"
                                stroke-width="2.5">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
                            </svg>Add Product
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>


<%- include('../partials/footer') %>