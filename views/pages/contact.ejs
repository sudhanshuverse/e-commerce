<%- include('../partials/header') %>

<main style="width: 100%; padding: 0 1rem;">
  <div style="width: 100%; max-width: 1400px; margin-inline: auto;">

    <!-- Heading -->
    <div style="display: flex; align-items: center; justify-content: center; font-size: clamp(1.5rem, 8vw, 2.5rem); text-transform: uppercase; color: #555; padding: 2rem 1rem; gap: 0.5rem;">
      <span>Contact <span style="color: black; font-weight: 400;">US</span></span>
      <span style="width: 50px; height: 50px;">
        <img src="/assets/icons/hero-first-icon.svg" alt="Line Icon" style="width: 100%; height: 100%;" />
      </span>
    </div>

    <!-- Image + Text Section -->
    <div style="display: flex; align-items: center; justify-content: space-between; gap: 1rem; padding: 2rem 0; flex-wrap: wrap;">

      <!-- Image -->
      <div style="width: 100%; max-width: 500px;">
        <img src="/assets/images/contact_img.png" alt="Contact Image" style="width: 100%; height: 100%;" />
      </div>

      <!-- Text -->
      <div style="width: 100%; max-width: 750px; display: flex; flex-direction: column; gap: 1rem; justify-content: center;">

        <h1 style="color: #333; font-weight: 500;">Our Store</h1>
        <p style="color: #555; line-height: 1.5rem;">
          B-27, 2nd Floor <br />
          Lajpat Nagar II, New Delhi – 110024, India <br /><br />
          Tel: +91 95084145** <br />
          Email: sudhanshu95084145@gmail.com
        </p>

        <h1 style="color: #333; font-weight: 500;">Careers at Forever</h1>
        <p style="color: #555; line-height: 1.5rem;">Learn more about our teams and job openings.</p>

        <button style="width: 150px; background-color: transparent; padding: 1rem; border: 1px solid #ddd; color: #333; cursor: pointer; font-family: inherit;">
          Explore Jobs
        </button>

      </div>
    </div>

  </div>

  <!-- Subscribe Section -->
  <div style="background-color: #f5f5f5; padding: 4rem 1rem; text-align: center; margin-top: 2rem;">
    <h2 style="font-size: clamp(1.2rem, 5vw, 2rem); color: #333; margin-bottom: 0.5rem;">
      Subscribe Now & Get <span style="color: #555;">20% Off</span>
    </h2>
    <p style="color: #888; margin-bottom: 1.5rem; font-size: 0.9rem;">
      Stay updated with our latest arrivals and exclusive offers.
    </p>
    <form action="/subscribe" method="POST" style="display: flex; justify-content: center; max-width: 500px; margin-inline: auto;">
      <input
        type="email"
        name="email"
        placeholder="Enter your email"
        style="flex: 1; padding: 0.75rem 1rem; border: 1px solid #ccc; outline: none; font-size: 0.9rem;"
      />
      <button
        type="submit"
        style="padding: 0.75rem 1.5rem; background-color: black; color: white; font-size: 0.85rem; font-weight: 600; border: none; cursor: pointer; text-transform: uppercase; letter-spacing: 0.05em;"
      >
        Subscribe
      </button>
    </form>
  </div>

</main>

<%- include('../partials/footer') %>