<%- include('../partials/header') %>

<div class="min-h-screen text-white py-8">
  <div class="max-w-6xl mx-auto">

    <!-- Header -->
    <div class="mb-6">
      <h1 class="text-3xl font-bold text-black">Your Cart</h1>
      <p class="text-sm text-gray-700 mt-1">Review items and proceed to checkout</p>
    </div>

    <% if (cartProducts.length === 0) { %>
      <!-- Empty Cart State -->
      <div class="flex flex-col items-center justify-center border-2 border-dashed border-gray-700 rounded-2xl p-12">
        <p class="text-xl mb-4 text-black font-bold">Your cart is empty</p>
        <p class="text-sm text-gray-700 mb-6">Add products from the store to see them here.</p>
        <a href="/products" class="px-5 py-2 bg-gray-200 text-black rounded-lg font-medium hover:bg-white transition-colors">
          Continue Shopping
        </a>
      </div>

    <% } else { %>
      <div class="flex flex-col lg:flex-row gap-6 items-start">

        <!-- Cart Items -->
        <div class="w-full lg:flex-1 space-y-4">
          <% cartProducts.forEach(function(item) { %>
            <div class="flex items-center gap-2 lg:gap-4 border border-gray-200 rounded-2xl p-3 lg:p-4">

              <!-- Product Image -->
              <img
                src="<%= item.product.img %>"
                alt="<%= item.product.name %>"
                class="w-24 h-24 sm:w-28 sm:h-28 object-cover rounded-xl flex-shrink-0"
              />

              <!-- Product Info -->
              <div class="flex-1 min-w-0">
                <h2 class="text-base sm:text-lg font-bold text-black truncate"><%= item.product.name %></h2>
                <p class="text-sm text-gray-600 mt-0.5"><%= item.product.category %></p>

                <!-- Quantity Controls -->
                <div class="flex items-center lg:gap-3 mt-3">
                  <div class="flex items-center bg-gray-300 border border-black rounded-lg overflow-hidden">

                    <!-- Decrease -->
                    <form action="/cart/remove/<%= item.product.id %>" method="POST" style="display:inline;">
                      <button type="submit" class="px-3 py-2 text-gray-700 transition-colors cursor-pointer" aria-label="decrease">
                        &minus;
                      </button>
                    </form>

                    <!-- Quantity Display -->
                    <div class="lg:px-4 lg:py-2 text-gray-900 font-semibold min-w-[2.5rem] text-center">
                      <%= item.quantity %>
                    </div>

                    <!-- Increase -->
                    <form action="/cart/add/<%= item.product.id %>" method="POST" style="display:inline;">
                      <button type="submit" class="px-3 py-2 text-gray-700 transition-colors cursor-pointer" aria-label="increase">
                        &#43;
                      </button>
                    </form>

                  </div>
                </div>
              </div>

              <!-- Price & Remove -->
              <div class="flex flex-col items-end justify-between h-full gap-8 flex-shrink-0">
                <span class="text-lg font-bold text-black">
                  $<%= (Number(item.product.price) * item.quantity).toFixed(2) %>
                </span>

                <form action="/cart/remove-all/<%= item.product.id %>" method="POST">
                  <button type="submit" class="flex items-center gap-1.5 text-red-500 hover:text-red-400 text-sm transition-colors cursor-pointer">
                    🗑 <span>Remove</span>
                  </button>
                </form>
              </div>

            </div>
          <% }); %>
        </div>

        <!-- Order Summary Sidebar -->
        <aside class="w-full lg:w-80 border border-gray-200 rounded-2xl p-6 lg:sticky lg:top-4 bg-[#f8f8f8]">
          <h3 class="text-xl font-bold text-black mb-5">Order Summary</h3>

          <div class="flex justify-between text-gray-600 mb-3">
            <span>Subtotal</span>
            <span class="text-black font-bold">$<%= subtotal.toFixed(2) %></span>
          </div>
          <div class="flex justify-between text-gray-600 mb-3">
            <span>Shipping</span>
            <span class="text-black font-bold">$<%= shipping.toFixed(2) %></span>
          </div>

          <div class="border-t border-gray-700 my-4"></div>

          <div class="flex justify-between font-bold text-black text-lg mb-6">
            <span>Total</span>
            <span>$<%= total %></span>
          </div>

          <!-- Checkout -->
          <form action="/checkout" method="POST">
            <button type="submit" class="w-full py-3 bg-[#1fffb4] text-black font-bold rounded-xl mb-3 cursor-pointer hover:bg-[#17d99a] transition-colors">
              Checkout
            </button>
          </form>

          <!-- Clear Cart -->
          <form action="/cart/clear" method="POST">
            <button type="submit" class="w-full py-2.5 border border-gray-700 text-black font-bold cursor-pointer rounded-xl hover:bg-gray-800 hover:text-white transition-colors text-sm">
              Clear Cart
            </button>
          </form>

        </aside>
      </div>
    <% } %>

  </div>
</div>

<%- include('../partials/footer') %>