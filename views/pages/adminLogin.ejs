<%- include('../partials/header') %>

<div class="min-h-screen flex items-center justify-center py-12 px-4">
  <div class="w-full max-w-md bg-[#f5f5f5] shadow-sm rounded-2xl p-8">
    <!-- Admin Badge -->
    <div class="flex items-center justify-center mb-6">
      <span class="bg-gray-900 text-white text-xs font-semibold px-3 py-1 rounded-full tracking-widest uppercase">Admin Portal</span>
    </div>
    <h2 class="text-2xl font-semibold text-gray-900 mb-1">Admin Sign In</h2>
    <p class="text-sm text-gray-600 mb-6">Access restricted to authorized administrators only.</p>
    <!-- Show error messages from server -->
    <% if (typeof errors !== 'undefined') { %>
      <% if (errors.email) { %>
        <p class="text-sm text-red-600 mb-2"><%= errors.email %></p>
      <% } %>
      <% if (errors.password) { %>
        <p class="text-sm text-red-600 mb-2"><%= errors.password %></p>
      <% } %>
      <% if (errors.general) { %>
        <p class="text-sm text-red-600 mb-2"><%= errors.general %></p>
      <% } %>
    <% } %>
    <form action="/admin/signin" method="POST" class="space-y-4">
      <!-- Email Field -->
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Admin Email</label>
        <input type="email" name="email" placeholder="admin@example.com" value="<%= typeof formData !== 'undefined' ? formData.email : '' %>" class="w-full px-4 py-2 bg-white border border-gray-200 rounded-md text-gray-800 focus:outline-none focus:ring-2 focus:ring-gray-400" required autocomplete="username"/>
      </div>

      <!-- Password Field -->
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Password</label>
        <div class="relative">
          <input type="password" name="password" id="adminPassword" placeholder="Enter admin password" class="w-full px-4 py-2 bg-white border border-gray-200 rounded-md text-gray-800 focus:outline-none focus:ring-2 focus:ring-gray-400 pr-10" required autocomplete="current-password"/>
          <!-- Toggle Password Visibility -->
          <button type="button" onclick="togglePassword()" class="absolute inset-y-0 right-3 flex items-center text-gray-400 hover:text-gray-700" tabindex="-1">
            <svg id="eyeIcon" xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.477 0 8.268 2.943 9.542 7-1.274 4.057-5.065 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
            </svg>
          </button>
        </div>
      </div>

      <!-- Submit Button -->
      <button class="w-full mt-2 bg-gray-900 hover:bg-gray-700 text-white font-medium py-2 rounded-md transition cursor-pointer" type="submit" >Sign In as Admin</button>
    </form>
  </div>
</div>

<script>
  function togglePassword() {
    const input = document.getElementById('adminPassword');
    const icon = document.getElementById('eyeIcon');
    if (input.type === 'password') {
      input.type = 'text';
      icon.innerHTML = `
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
          d="M13.875 18.825A10.05 10.05 0 0112 19c-4.477 0-8.268-2.943-9.542-7a9.956 9.956 0 012.293-3.95M6.696 6.696A9.953 9.953 0 0112 5c4.477 0 8.268 2.943 9.542 7a9.973 9.973 0 01-4.238 5.247M3 3l18 18" />
      `;
    } else {
      input.type = 'password';
      icon.innerHTML = `
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
          d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
          d="M2.458 12C3.732 7.943 7.523 5 12 5c4.477 0 8.268 2.943 9.542 7-1.274 4.057-5.065 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
      `;
    }
  }
</script>

<%- include('../partials/footer') %>