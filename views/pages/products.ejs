<%- include('../partials/header') %>

  <div class="max-w-[1400px] mx-auto px-4 py-10">
    <h1 class="text-2xl lg:text-3xl font-bold mb-3 text-center">Our Premium Products</h1>
    <p class="mb-5 text-center text-sm text-gray-500">Browse our premium collection of products</p>
    <!-- Search -->
    <form action="/products" method="GET" class="text-center mb-6">
      <input type="text" name="search" value="<%= search %>" placeholder="Search your favourite product"
        class="w-[80%] bg-[#f0f0f0] text-base p-4 rounded-xl outline-none border border-gray-200" />
    </form>

    <!-- Category Filter -->
    <div class="flex gap-3 flex-wrap justify-center mb-8">

      <a href="/products?category=All" class="px-5 py-2 rounded-full text-sm font-medium transition
<%= category === 'All' ? 'bg-gray-900 text-white' : 'bg-[#f0f0f0] text-gray-700 hover:bg-gray-200' %>">
        All
      </a>

      <a href="/products?category=Electronics" class="px-5 py-2 rounded-full text-sm font-medium transition
<%= category === 'Electronics' ? 'bg-gray-900 text-white' : 'bg-[#f0f0f0] text-gray-700 hover:bg-gray-200' %>">
        Electronics
      </a>

      <a href="/products?category=Fashion" class="px-5 py-2 rounded-full text-sm font-medium transition
<%= category === 'Fashion' ? 'bg-gray-900 text-white' : 'bg-[#f0f0f0] text-gray-700 hover:bg-gray-200' %>">
        Fashion
      </a>

      <a href="/products?category=Beauty" class="px-5 py-2 rounded-full text-sm font-medium transition
<%= category === 'Beauty' ? 'bg-gray-900 text-white' : 'bg-[#f0f0f0] text-gray-700 hover:bg-gray-200' %>">
        Beauty
      </a>

      <a href="/products?category=Sports" class="px-5 py-2 rounded-full text-sm font-medium transition
<%= category === 'Sports' ? 'bg-gray-900 text-white' : 'bg-[#f0f0f0] text-gray-700 hover:bg-gray-200' %>">
        Sports
      </a>

      <a href="/products?category=Accessories" class="px-5 py-2 rounded-full text-sm font-medium transition
<%= category === 'Accessories' ? 'bg-gray-900 text-white' : 'bg-[#f0f0f0] text-gray-700 hover:bg-gray-200' %>">
        Accessories
      </a>

    </div>

    <!-- Products Grid -->
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4">

      <% products.forEach(function(product){ %>

        <div class="border border-gray-100 rounded-2xl overflow-hidden bg-white
transition-all duration-300 transform hover:-translate-y-1
hover:shadow-xl hover:border-gray-200">

          <!-- Image -->
          <div class="overflow-hidden">
            <a href="/products/<%= product._id %>">
              <img src="<%= product.img %>" alt="<%= product.name %>"
                class="w-full h-52 object-cover transition-transform duration-300 hover:scale-110" />
            </a>
          </div>

          <!-- Info -->
          <div class="p-3">

            <p class="text-xs text-gray-400 uppercase tracking-wide mb-1">
              <%= product.category %>
            </p>

            <a href="/products/<%= product._id %>">
              <h2 class="text-sm font-semibold text-gray-900 truncate hover:text-gray-700">
                <%= product.name %>
              </h2>
            </a>

            <!-- Stars -->
            <div class="flex items-center gap-1 mt-1 mb-2">

              <% for(let i=1;i<=5;i++){ %>

                <i class="fa fa-star text-xs <%= i <= product.rating ? 'text-yellow-400' : 'text-gray-200' %>"></i>

                <% } %>

                  <span class="text-xs text-gray-400 ml-1">
                    (<%= product.reviews %>)
                  </span>

            </div>

            <!-- Price + Buttons -->
            <div class="flex items-center justify-between mt-2">

              <span class="text-base font-bold text-gray-900">
                &#8377; <%= product.price.toFixed(2) %>
              </span>

              <div class="flex gap-2">

                <form action="/cart/add/<%= product._id %>" method="POST">
                  <button class="bg-black text-white text-xs px-3 py-2 rounded-xl hover:bg-gray-800 transition">
                    Add to Cart
                  </button>
                </form>

                <a href="/products/<%= product._id %>">
                  <button class="bg-teal-600 text-white text-xs px-3 py-2 rounded-xl hover:bg-teal-700 transition">
                    Details
                  </button>
                </a>

              </div>

            </div>

          </div>

        </div>

        <% }) %>

    </div>
  </div>

  <%- include('../partials/footer') %>