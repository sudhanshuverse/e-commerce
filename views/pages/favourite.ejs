<%- include('../partials/header') %>

<div class="min-h-screen py-8 px-4">
  <div class="max-w-6xl mx-auto">

    <!-- Header -->
    <div class="mb-6">
      <h1 class="text-3xl font-bold text-black">My Favourites</h1>
      <p class="text-sm text-gray-700 mt-1">Items you loved</p>
    </div>

    <% if (favourites.length === 0) { %>
      <!-- Empty State -->
      <div class="flex flex-col items-center justify-center border-2 border-dashed border-gray-300 rounded-2xl p-12">
        <p class="text-xl mb-4 text-black font-bold">No favourites yet</p>
        <p class="text-sm text-gray-600 mb-6">Browse the store and add items you love.</p>
        <a href="/products" class="px-5 py-2 bg-gray-200 text-black rounded-lg font-medium hover:bg-gray-300 transition-colors">Continue Shopping</a>
      </div>
  
    <% } else { %>
      <!-- Products Grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
        <% favourites.forEach(function(item) { %>
          <div class="border border-gray-200 rounded-2xl overflow-hidden bg-[#f8f8f8] hover:shadow-md transition-shadow">
            <!-- Product Image -->
            <div class="relative">
              <img src="<%= item.img %>" alt="<%= item.name %>" class="w-full h-56 object-cover"/>
              <!-- Remove from Favourite Button -->
              <form action="/favourite/remove/<%= item.id %>" method="POST">
                <button type="submit" class="absolute top-2 right-2 bg-white rounded-full p-2 shadow text-red-500 hover:text-red-700 transition-colors cursor-pointer" title="Remove from favourites">❤️</button>
              </form>
            </div>

            <!-- Product Info -->
            <div class="p-4">
              <p class="text-xs text-gray-500 mb-1"><%= item.category %></p>
              <h2 class="text-base font-bold text-black truncate"><%= item.name %></h2>
              <p class="text-sm font-semibold text-gray-800 mt-1">$<%= item.price.toFixed(2) %></p>
              <!-- Add to Cart -->
              <form action="/cart/add/<%= item.id %>" method="POST" class="mt-3">
                <button type="submit" class="w-full py-2 bg-gray-900 hover:bg-gray-700 text-white text-sm font-medium rounded-xl transition-colors cursor-pointer" >   Add to Cart/button>
              </form>
            </div>
          </div>
        <% }); %>
      </div>
    <% } %>
  </div>
</div>

<%- include('../partials/footer') %>